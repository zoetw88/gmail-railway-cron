# Railway Variables：整段必須是合法 JSON；切勿提交真實值。
GMAIL_ACCOUNTS_JSON=[{"name":"A","email":"a@example.com","client_id":"...apps.googleusercontent.com","client_secret":"...","refresh_token":"..."},{"name":"B","email":"b@example.com","client_id":"...","client_secret":"...","refresh_token":"..."},{"name":"C","email":"c@example.com","client_id":"...","client_secret":"...","refresh_token":"..."},{"name":"D","email":"d@example.com","client_id":"...","client_secret":"...","refresh_token":"..."}]
# 第一次部署務必使用 true；確認 Railway logs 後才改 false。
DRY_RUN=true
EMAIL_SUMMARY_ENABLED=true
LOOKBACK=1d
RULES_PATH=rules.json

# 選用：GLM 只接收寄件者、主旨與最長 500 字 snippet；不傳完整信件本文。
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o
# Backward-compatible GLM settings; used when AI_* is absent.
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-4.7-flashx
AI_CONFIDENCE_THRESHOLD=0.90
AI_MAX_MESSAGES=20
# 預設只在摘要提出分類建議；即使開啟也不會由 AI 封存郵件。
AI_APPLY_LABELS=false

# 選用：LINE Messaging API（不是已終止的 LINE Notify）。
LINE_ENABLED=false
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# 選用：私人雲端儀表板。只傳分類統計與 AI 短摘要，不傳郵件全文。
DASHBOARD_ENABLED=false
DASHBOARD_URL=https://your-private-dashboard.example
DASHBOARD_INGEST_TOKEN=
